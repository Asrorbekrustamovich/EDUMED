generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("student") // student, teacher, admin
  university String?
  year      String?
  createdAt DateTime @default(now())
  
  // Stats
  points    Int      @default(0)
  casesDone Int      @default(0)
  ethicsScore Int    @default(0)
  ethicsDone  Int    @default(0)
  
  // Relations
  results   SimulationResult[]
  volunteerApps VolunteerApplication[]
  incorrectAnswers IncorrectAnswer[]
  feedbacks        Feedback[]
}

model Case {
  id          String   @id @default(uuid())
  title       String
  description String
  difficulty  String
  category    String
  isActive    Boolean  @default(true)
  
  results     SimulationResult[]
  steps       SimulationStep[]
}

model SimulationStep {
  id            String   @id @default(uuid())
  caseId        String
  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  systemMessage String
  stepOrder     Int      @default(0)
  
  options       SimulationOption[]
}

model SimulationOption {
  id              String   @id @default(uuid())
  stepId          String
  step            SimulationStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  text            String
  patientResponse String
  emotionClass    String   @default("calm")
  emotionText     String   @default("😌 Tinchlangan")
  vitalsHr        Int      @default(80)
  scoreDelta      Int      @default(0)
  nextStepId      String?
}

model EthicsQuestion {
  id                 String   @id @default(uuid())
  question           String
  lawText            String
  options            String   // JSON stringified
  correctAnswer      Int
  explanations       String   // JSON stringified
  explanationCorrect String
}

model SimulationResult {
  id          String   @id @default(uuid())
  score       Int
  duration    Int      // in minutes
  createdAt   DateTime @default(now())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
}

model VolunteerProject {
  id           String   @id @default(uuid())
  avatar       String   @default("🏥")
  title        String
  description  String
  date         String
  location     String
  slotsMax     Int      @default(20)
  pointsReward Int      @default(500)
  createdAt    DateTime @default(now())
  
  applications VolunteerApplication[]
}

model VolunteerApplication {
  id        String   @id @default(uuid())
  projectId String
  project   VolunteerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model IncorrectAnswer {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionText   String
  selectedOption String
  correctOption  String
  type           String   // "ethics" or "simulation"
  createdAt      DateTime @default(now())
}

model Feedback {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherId   String
  teacherName String
  message     String
  createdAt   DateTime @default(now())
  isRead      Boolean  @default(false)
}
